generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  name            String?
  password        String
  role            Role          @default(USER)
  organization_id String?
  organization    Organization? @relation(fields: [organization_id], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}


model Organization {
  id                    String         @id @default(uuid())
  name                  String
  whatsapp_phone_id     String         @unique
  whatsapp_token        String
  whatsapp_verify_token String         @default("abelops_verify")
  openai_token          String?
  message_limit         Int            @default(1000)
  message_count         Int            @default(0)
  contacts              Contact[]
  conversations         Conversation[]
  messages              Message[]
  users                 User[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model Contact {
  id                String       @id @default(uuid())
  phone_number      String       @unique
  name              String?
  avatar            String       @default("")
  last_message      String       @default("")
  last_message_time DateTime     @default(now())
  unread_count      Int          @default(0)
  organization_id   String?
  organization      Organization? @relation(fields: [organization_id], references: [id])
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}


model Conversation {
  id                String       @id @default(uuid())
  phone_number      String
  ai_reply_enabled  Boolean      @default(true)
  last_interaction  DateTime     @default(now())
  status            String       @default("active")
  organization_id   String?
  organization      Organization? @relation(fields: [organization_id], references: [id])
  messages          Message[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model Message {
  id              String        @id @default(uuid())
  phone_number    String
  message         String
  message_type    String        // user, bot
  message_id      String?       @unique
  timestamp       DateTime      @default(now())
  conversation_id String?
  conversation    Conversation? @relation(fields: [conversation_id], references: [id])
  organization_id String?
  organization    Organization? @relation(fields: [organization_id], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

